# ============================================
# 환경변수 예시 파일
# ============================================
#   cp .env.example .env
#
# 개발환경: docker compose up -d 로 DB/Redis 실행 후
#           DATABASE_URL과 REDIS_URL은 아래 기본값 그대로 사용
# ============================================

# 서버
PORT=4001

# 데이터베이스 (개발: docker compose의 PostgreSQL)
DATABASE_URL="postgresql://nearbybook:nearbybook1234@localhost:5432/nearbybook"

# Redis (개발: docker compose의 Redis)
REDIS_URL="redis://localhost:6379"

# 외부 API
LIBRARY_BIGDATA_API_KEY=""
DISCORD_WEBHOOK_URL=""
NAVER_CLIENT_ID=""
NAVER_SECRET=""

# Meilisearch (자동완성 검색)
MEILISEARCH_HOST="https://search.nearbybook.kr"
MEILISEARCH_SEARCH_API_KEY=
MEILISEARCH_ADMIN_API_KEY=
JWT_SECRET=""
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
