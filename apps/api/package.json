{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "db:generate-dev": "cross-env NODE_ENV=development drizzle-kit generate",
    "db:migrate-dev": "cross-env NODE_ENV=development drizzle-kit migrate",
    "db:push-dev": "cross-env NODE_ENV=development drizzle-kit push",
    "db:studio-dev": "cross-env NODE_ENV=development drizzle-kit studio",
    "db:generate-prod": "cross-env NODE_ENV=production drizzle-kit generate",
    "db:migrate-prod": "cross-env NODE_ENV=production drizzle-kit migrate",
    "db:push-prod": "cross-env NODE_ENV=production drizzle-kit push",
    "db:studio-prod": "cross-env NODE_ENV=production drizzle-kit studio",
    "start": "nest start",
    "dev": "docker compose up -d && cross-env NODE_ENV=development nest start --watch",
    "start:debug": "docker compose up -d && nest start --debug --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.0.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.4.0",
    "@toss/nestjs-aop": "^2.1.7",
    "axios": "^1.13.2",
    "bullmq": "^5.70.1",
    "cache-manager": "^7.2.2",
    "cacheable-lookup": "^7.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "fast-xml-parser": "^5.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "meilisearch": "^0.55.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "drizzle-kit": "^0.31.8",
    "@workspace/types": "*"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "29.5.14",
    "@types/node": "^22.18.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "~29.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
